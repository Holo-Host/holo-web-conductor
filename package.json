{
  "name": "holo-web-conductor",
  "version": "0.1.0",
  "private": true,
  "description": "Browser extension implementation of Holochain conductor and Lair keystore",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:extension": "npm run build --workspace=@hwc/core --workspace=@holo-host/lair --workspace=@hwc/shared --workspace=@hwc/extension",
    "pretest": "npm run build --workspace=@hwc/test-zome && cp packages/test-zome/target/wasm32-unknown-unknown/release/test_zome.wasm packages/extension/test/test-zome.wasm",
    "typecheck": "tsc -p packages/shared/tsconfig.json && tsc -p packages/lair/tsconfig.json && tsc -p packages/core/tsconfig.json && tsc -p packages/client/tsconfig.json && tsc --noEmit -p packages/extension/tsconfig.json",
    "test": "npm run typecheck && npm run build --workspace=@hwc/extension && npm run test:unit && npm run test:integration",
    "test:unit": "npm run test --workspaces",
    "test:integration": "vitest run packages/core/src/ribosome/integration.test.ts packages/core/src/ribosome/genesis-self-check.test.ts",
    "test:watch": "vitest watch",
    "lint": "npm run lint --workspaces",
    "clean": "npm run clean --workspaces",
    "e2e": "npx tsx packages/e2e/src/index.ts",
    "e2e:test": "npx tsx packages/e2e/src/index.ts test",
    "e2e:test:ziptest": "npx tsx packages/e2e/src/index.ts test --project=chromium-extension --test=tests/ziptest.test.ts --headed",
    "e2e:test:mewsfeed": "npx tsx packages/e2e/src/index.ts test --project=chromium-extension --test=tests/mewsfeed.test.ts --headed",
    "e2e:test:cross-browser": "npx tsx packages/e2e/src/index.ts test --project=cross-browser --test=tests/cross-browser.test.ts --headed",
    "e2e:env": "npx tsx packages/e2e/src/index.ts env",
    "e2e:env:start": "npx tsx packages/e2e/src/index.ts env start",
    "e2e:env:stop": "npx tsx packages/e2e/src/index.ts env stop",
    "e2e:env:status": "npx tsx packages/e2e/src/index.ts env status",
    "e2e:logs": "npx tsx packages/e2e/src/index.ts logs",
    "release": "npm run build:extension && ./scripts/package-extension.sh"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "libsodium": "^0.8.0",
    "libsodium-wrappers": "^0.8.0",
    "tslib": "^2.8.1"
  },
  "overrides": {
    "libsodium": "^0.8.0",
    "libsodium-wrappers": "^0.8.0"
  }
}
