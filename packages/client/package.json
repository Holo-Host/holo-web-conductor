{
  "name": "@zippy/fishy-client",
  "version": "0.1.0",
  "description": "Holochain AppClient for Fishy browser extension - drop-in replacement for @holochain/client",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@holochain/client": "^0.18.0 || ^0.19.0 || ^0.20.0"
  },
  "devDependencies": {
    "@holochain/client": "^0.20.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vitest": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/fishy"
  },
  "keywords": [
    "holochain",
    "browser-extension",
    "zero-arc",
    "fishy"
  ],
  "license": "MIT"
}
