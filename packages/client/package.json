{
  "name": "@holo-host/web-conductor-client",
  "version": "0.1.0",
  "description": "Holochain AppClient for the Holo Web Conductor browser extension - drop-in replacement for @holochain/client",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && npm run copy-to-test",
    "copy-to-test": "mkdir -p ../extension/test/lib && cp dist/index.js ../extension/test/lib/web-conductor-client.js",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@msgpack/msgpack": "^2.8.0 || ^3.0.0"
  },
  "peerDependencies": {
    "@holochain/client": "^0.18.0 || ^0.19.0 || ^0.20.0"
  },
  "devDependencies": {
    "@holochain/client": "^0.20.1",
    "jsdom": "^27.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vitest": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/holo-host/holo-web-conductor"
  },
  "keywords": [
    "holochain",
    "browser-extension",
    "zero-arc",
    "web-conductor",
    "holo"
  ],
  "license": "MIT"
}
