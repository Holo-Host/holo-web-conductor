{
  "name": "@fishy/e2e",
  "version": "0.0.1",
  "private": true,
  "description": "E2E test runner for Fishy browser extension",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "fishy-e2e": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "env": "tsx src/index.ts env",
    "logs": "tsx src/index.ts logs",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@playwright/test": "^1.40.0",
    "commander": "^12.0.0",
    "tail": "^2.2.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/tail": "^2.2.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.0.0"
  }
}
