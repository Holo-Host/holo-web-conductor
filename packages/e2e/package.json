{
  "name": "@hwc/e2e",
  "version": "0.1.0",
  "private": true,
  "description": "E2E test runner for Holo Web Conductor browser extension",
  "license": "CAL-1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hwc-e2e": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "env": "tsx src/index.ts env",
    "logs": "tsx src/index.ts logs",
    "test": "echo 'E2E tests require headed browser + linker. Run: npm run e2e:test (from repo root)'",
    "test:e2e": "playwright test",
    "test:headed": "playwright test --headed",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@playwright/test": "^1.40.0",
    "commander": "^12.0.0",
    "tail": "^2.2.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/tail": "^2.2.3",
    "http-server": "^14.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.0.0"
  }
}
