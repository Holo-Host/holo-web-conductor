{
  "manifest_version": 3,
  "name": "Holo Web Conductor",
  "version": "0.1.0",
  "version_name": "0.1.0-rc.3",
  "description": "Browser extension implementation of Holochain conductor",
  "icons": {
    "16": "icons/holochain-16.png",
    "48": "icons/holochain-48.png",
    "128": "icons/holochain-128.png"
  },
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background/index.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Holo Web Conductor",
    "default_icon": {
      "16": "icons/holochain-16.png",
      "48": "icons/holochain-48.png",
      "128": "icons/holochain-128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["inject/index.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "holochain@holo.host",
      "strict_min_version": "128.0"
    }
  }
}
