{
  "manifest_version": 3,
  "name": "Fishy - Holochain in the Browser",
  "version": "0.0.1",
  "description": "Browser extension implementation of Holochain conductor",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Fishy"
  },
  "web_accessible_resources": [
    {
      "resources": ["inject/index.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
