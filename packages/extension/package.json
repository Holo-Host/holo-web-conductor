{
  "name": "@hwc/extension",
  "version": "0.1.0",
  "private": true,
  "description": "Holo Web Conductor browser extension - Holochain conductor in the browser",
  "license": "CAL-1.0",
  "type": "module",
  "scripts": {
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "BROWSER=chrome vite build",
    "build:firefox": "BROWSER=firefox vite build",
    "dev": "BROWSER=chrome vite build --watch",
    "dev:firefox": "BROWSER=firefox vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "clean": "rm -rf dist-chrome dist-firefox"
  },
  "dependencies": {
    "@hwc/core": "*",
    "@holo-host/lair": "*",
    "@hwc/shared": "*",
    "@holochain/client": "^0.20.1",
    "@sqlite.org/sqlite-wasm": "^3.51.1-build2",
    "libsodium-wrappers": "^0.8.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.256",
    "@types/libsodium-wrappers": "^0.7.14",
    "vite": "^5.0.0"
  }
}
