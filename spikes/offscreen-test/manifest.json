{
  "manifest_version": 3,
  "name": "Offscreen WASM Test",
  "version": "0.0.1",
  "description": "Tests if WASM can run in offscreen document with sync XHR",
  "permissions": [
    "offscreen"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Test Offscreen WASM"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
